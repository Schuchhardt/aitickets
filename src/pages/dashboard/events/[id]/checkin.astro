---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { getSupabaseAdmin } from "../../../../lib/auth-helpers";
import { createSupabaseServerClient } from "../../../../lib/supabaseServer";
import ValidateQR from "../../../../components/ValidateQR.vue";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro);
const supabaseAdmin = getSupabaseAdmin();

const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect("/organizadores/login");
}

const { data: dbUser } = await supabase
    .from("users")
    .select("id, organization_id")
    .eq("auth_user_id", user.id)
    .single();

if (!dbUser || !dbUser.organization_id) {
    return Astro.redirect("/dashboard/events");
}

// Fetch event
const { data: event, error } = await supabaseAdmin
    .from("events")
    .select("*")
    .eq("id", id)
    .eq("organization_id", dbUser.organization_id)
    .single();

if (error || !event) {
    return Astro.redirect("/dashboard/events");
}

// Load attendees with full info
const { data: event_attendees, error: attendeesError } = await supabaseAdmin
    .from("event_attendees")
    .select(`
        id,
        event_id,
        qr_code,
        status,
        validated_at,
        attendees (
            first_name,
            last_name,
            email
        ),
        event_tickets (
            ticket_name
        )
    `)
    .eq("event_id", event.id);

if (attendeesError) {
    console.error("Error loading attendees:", attendeesError);
    event.attendees = [];
} else {
    event.attendees = event_attendees || [];
}
---

<DashboardLayout title={`Check-in · ${event.name}`}>
    <div class="mb-6">
        <div class="flex items-center gap-3 mb-2">
            <a
                href="/dashboard/events"
                class="text-gray-500 hover:text-black transition">Eventos</a
            >
            <span class="text-gray-300">/</span>
            <a
                href={`/dashboard/events/${event.id}`}
                class="text-gray-500 hover:text-black transition truncate max-w-[200px]"
                >{event.name}</a
            >
            <span class="text-gray-300">/</span>
            <span class="text-gray-900 font-medium">Check-in</span>
        </div>
        <h1 class="text-3xl font-bold font-[Unbounded]">Check-in</h1>
        <p class="text-gray-500 mt-1">Escanea los códigos QR de los asistentes para validar su entrada.</p>
    </div>

    <ValidateQR event={event} client:load />
</DashboardLayout>
