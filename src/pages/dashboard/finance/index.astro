---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { createSupabaseServerClient } from "../../../lib/supabaseServer";
import { getSupabaseAdmin } from "../../../lib/auth-helpers";

const supabase = createSupabaseServerClient(Astro);
const supabaseAdmin = getSupabaseAdmin();
const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect("/organizadores/login");
}

const { data: dbUser } = await supabase
    .from("users")
    .select("organization_id")
    .eq("auth_user_id", user.id)
    .single();

let totalRevenue = 0;
let pendingPayout = 0;
let transactions: Array<{event: string; amount: number; fee: number; qty: number; date: string; status: string}> = [];

if (dbUser?.organization_id) {
    const { data: orgEvents } = await supabaseAdmin
        .from("events")
        .select("id, name")
        .eq("organization_id", dbUser.organization_id);

    if (orgEvents && orgEvents.length > 0) {
        const eventIds = orgEvents.map((e) => e.id);
        const eventNameMap = Object.fromEntries(orgEvents.map((e) => [e.id, e.name]));

        // Get all paid orders
        const { data: orders } = await supabaseAdmin
            .from("event_orders")
            .select("id, event_id, amount, payment_fee, total_payment, ticket_qty, created_at, status")
            .in("event_id", eventIds)
            .order("created_at", { ascending: false });

        if (orders) {
            totalRevenue = orders
                .filter((o) => o.status === "paid")
                .reduce((sum, o) => sum + (o.amount || 0), 0);

            // Get already withdrawn amounts
            const { data: withdrawals } = await supabaseAdmin
                .from("event_withdrawals")
                .select("amount, status")
                .in("event_id", eventIds)
                .in("status", ["paid", "requested"]);

            const withdrawnAmount = (withdrawals || []).reduce((sum, w) => sum + Number(w.amount || 0), 0);
            pendingPayout = totalRevenue - withdrawnAmount;
            if (pendingPayout < 0) pendingPayout = 0;

            transactions = orders.map((o) => ({
                event: eventNameMap[o.event_id] || "—",
                amount: o.amount || 0,
                fee: o.payment_fee || 0,
                qty: o.ticket_qty || 0,
                date: new Date(o.created_at).toLocaleDateString("es-CL"),
                status: o.status,
            }));
        }
    }
}

const formatCLP = (amount: number) => `$${Number(amount).toLocaleString("es-CL")}`;
---

<DashboardLayout title="Ingresos">
    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-bold text-gray-900">
                Ingresos y Finanzas
            </h1>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div
                class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm"
            >
                <h3 class="text-gray-500 text-sm font-medium">
                    Ingresos Totales
                </h3>
                <p class="text-3xl font-bold mt-2">{formatCLP(totalRevenue)}</p>
            </div>
            <div
                class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm"
            >
                <h3 class="text-gray-500 text-sm font-medium">
                    Pendiente de Pago
                </h3>
                <p class="text-3xl font-bold mt-2">{formatCLP(pendingPayout)}</p>
            </div>
            <div
                class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm"
            >
                <h3 class="text-gray-500 text-sm font-medium">Próximo Pago</h3>
                <p class="text-lg font-semibold mt-2 text-gray-900">Próximamente</p>
            </div>
        </div>

        <!-- Transactions Table -->
        {transactions.length > 0 ? (
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-gray-100">
                    <h3 class="text-lg font-bold text-gray-900">Detalle de Transacciones</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-gray-600">
                        <thead class="bg-gray-50 text-gray-900 font-semibold border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-4">Evento</th>
                                <th class="px-6 py-4">Entradas</th>
                                <th class="px-6 py-4">Monto</th>
                                <th class="px-6 py-4">Comisión</th>
                                <th class="px-6 py-4">Fecha</th>
                                <th class="px-6 py-4">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            {transactions.map((t) => (
                                <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                                    <td class="px-6 py-4 font-medium text-gray-900">{t.event}</td>
                                    <td class="px-6 py-4">{t.qty}</td>
                                    <td class="px-6 py-4">{formatCLP(t.amount)}</td>
                                    <td class="px-6 py-4 text-gray-400">{formatCLP(t.fee)}</td>
                                    <td class="px-6 py-4">{t.date}</td>
                                    <td class="px-6 py-4">
                                        <span class={`px-2 py-1 rounded-full text-xs font-bold ${t.status === 'paid' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'}`}>
                                            {t.status === 'paid' ? 'Pagado' : t.status}
                                        </span>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        ) : (
            <div
                class="bg-white rounded-xl border border-gray-100 p-8 text-center shadow-sm mt-6"
            >
                <div class="max-w-md mx-auto">
                    <h3 class="text-lg font-medium text-gray-900 mb-2">
                        Detalle de Transacciones
                    </h3>
                    <p class="text-gray-500">
                        Aún no hay transacciones registradas. Cuando vendas entradas, aquí verás el desglose.
                    </p>
                </div>
            </div>
        )}
    </div>
</DashboardLayout>
