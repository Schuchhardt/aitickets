# Ejemplo de variables que Astro usará en tiempo de build o SSR

# Supabase (todas las operaciones son server-side)
SUPABASE_URL="https://<TU-PROYECTO>.supabase.co"
SUPABASE_ANON_KEY="<TU-ANON-KEY>"
SUPABASE_SERVICE_ROLE_KEY="<TU-SERVICE-ROLE-KEY>"

GOOGLE_MAPS_API_KEY="AIza......................"
MAILERLITE_API_TOKEN="eyJ0QiLCJ................"
SITE_URL=https://aitickets.cl

# Sentry Configuration for error tracking
SENTRY_DSN="https://your-sentry-dsn-here@sentry.io/project-id"
NODE_ENV=production

# Flow Payment Gateway
FLOW_API_KEY="your-flow-api-key"
FLOW_SECRET_KEY="your-flow-secret-key" 
FLOW_BASE_URL="https://flow.cl/api"

# Email Service
MAILGUN_API_KEY="your-mailgun-api-key"

# Zernio Social Media API (https://zernio.com)
ZERNIO_API_KEY="your-zernio-api-key"

# Meta Ads (Facebook/Instagram Ads)
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"

# Encryption key for stored tokens (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY="your-random-hex-key"
